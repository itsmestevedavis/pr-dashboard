# Copy to .env and fill in values for your team. The .env file is gitignored.

# GitHub logins to DM on Slack when nobody has reviewed your PR yet.
# The "Nudge" button uses this list in "first review" mode.
FRESH_REVIEWERS=teammate1,teammate2

# Slack channel ID (e.g. C01ABCDEF) where the "#Channel" button posts.
# Find it in Slack: right-click the channel → View channel details → copy ID at bottom.
TEAM_CHANNEL_ID=

# Default deploy environment shown on every My PRs card (e.g. csi-1, csi-2, csi-3).
# Leave empty to hide the Deploy button. See ~/.config/pr-dashboard/deploy_targets.json
# for the repo → env → workflow name mapping.
DEPLOY_TARGET=csi-3

# Optional overrides (defaults shown).
# HOST=127.0.0.1
# PORT=8765
# CACHE_TTL=30
